# Railway environment variables (Option B — per-service TOML workflow)
# Copy into Railway → Service → Variables.
# Service names must match the table in .railway/README.md

# --- postgres plugin (add via Railway dashboard) ---

# --- engine-math ---
# No required vars. Listens on $PORT (defaults to 8080 in code).

# --- backend-core ---
DATABASE_ADDRESS=${{Postgres.DATABASE_URL}}
ENGINE_MATH_URL=http://engine-math.railway.internal:8080
NAKAMA_LOG_LEVEL=INFO

# --- frontend-table ---
NEXT_PUBLIC_NAKAMA_HOST=https://${{backend-core.RAILWAY_PUBLIC_DOMAIN}}
NAKAMA_HOST=http://backend-core.railway.internal:7350
NAKAMA_SERVER_KEY=defaultkey
NEXT_PUBLIC_ENGINE_MATH_URL=https://${{engine-math.RAILWAY_PUBLIC_DOMAIN}}
ENGINE_MATH_URL=http://engine-math.railway.internal:8080
