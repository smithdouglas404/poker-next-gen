{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Club",
  "type": "object",
  "properties": {
    "accepts_global_wallet": {
      "title": "Accept Global Wallet",
      "description": "Let players buy in with their funded global wallet, not just club chips.",
      "type": "boolean",
      "x-order": 3
    },
    "currency": {
      "title": "Currency",
      "description": "Defaults to USD.",
      "type": "string",
      "enum": [
        "USD",
        "EUR",
        "GBP",
        "CAD",
        "AUD"
      ],
      "x-order": 2
    },
    "description": {
      "title": "Description",
      "type": "string",
      "maxLength": 280,
      "x-order": 1
    },
    "name": {
      "title": "Club Name",
      "type": "string",
      "minLength": 2,
      "maxLength": 64
    }
  },
  "required": [
    "name"
  ],
  "examples": [
    {
      "currency": "USD",
      "description": "Invite-only high stakes club",
      "name": "Midnight Hold'em Society"
    }
  ],
  "additionalProperties": false,
  "x-rpc": "club_create"
}
