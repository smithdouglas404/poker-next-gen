{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TableCreateRequest",
  "type": "object",
  "properties": {
    "allow_bomb_pot": {
      "title": "Allow Bomb Pot",
      "type": "boolean",
      "x-order": 11
    },
    "allow_insurance": {
      "title": "Allow Insurance",
      "type": "boolean",
      "x-order": 13
    },
    "allow_run_it_twice": {
      "title": "Allow Run It Twice",
      "type": "boolean",
      "x-order": 14
    },
    "allow_straddle": {
      "title": "Allow Straddle",
      "type": "boolean",
      "x-order": 10
    },
    "big_blind": {
      "title": "Big Blind",
      "type": "integer",
      "minimum": 0,
      "x-unit": "money_minor",
      "x-order": 3
    },
    "bomb_pot_ante": {
      "title": "Bomb Pot Ante",
      "type": "integer",
      "minimum": 0,
      "x-unit": "money_minor",
      "x-order": 12
    },
    "buy_in": {
      "title": "Buy-in",
      "type": "integer",
      "minimum": 0,
      "x-unit": "money_minor",
      "x-order": 4
    },
    "club_id": {
      "title": "Club",
      "description": "Bind to a club: buy-ins draw the club-allocated balance and pots are raked to the club.",
      "type": "string",
      "x-ref": "club",
      "x-order": 1
    },
    "duration_mins": {
      "title": "Auto-close (minutes)",
      "type": "integer",
      "minimum": 0,
      "maximum": 720,
      "x-unit": "minutes",
      "x-order": 9
    },
    "max_seats": {
      "title": "Seats at the table",
      "type": "integer",
      "minimum": 2,
      "maximum": 10,
      "x-unit": "count",
      "x-order": 5
    },
    "min_players": {
      "title": "Players needed to start",
      "type": "integer",
      "minimum": 2,
      "maximum": 10,
      "x-unit": "count",
      "x-order": 6
    },
    "name": {
      "title": "Table Name",
      "description": "Optional; a name is generated if omitted.",
      "type": "string"
    },
    "num_bots": {
      "title": "Bots",
      "type": "integer",
      "minimum": 0,
      "maximum": 9,
      "x-unit": "count",
      "x-order": 7
    },
    "small_blind": {
      "title": "Small Blind",
      "type": "integer",
      "minimum": 0,
      "x-unit": "money_minor",
      "x-order": 2
    },
    "variant": {
      "title": "Variant",
      "type": "string",
      "enum": [
        "holdem",
        "plo"
      ],
      "x-order": 8
    }
  },
  "examples": [
    {
      "big_blind": 200,
      "buy_in": 100000,
      "max_seats": 6,
      "min_players": 2,
      "name": "High Rollers",
      "num_bots": 5,
      "small_blind": 100,
      "variant": "holdem"
    }
  ],
  "additionalProperties": false,
  "x-rpc": "table_create"
}
