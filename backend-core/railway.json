{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": ["backend-core/**"]
  },
  "deploy": {
    "healthcheckPath": "/healthcheck",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ALWAYS"
  }
}
