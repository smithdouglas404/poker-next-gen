# --- OpenProject MCP review agent configuration ---
# Copy to .env for local dev. On Railway these are set as service variables.

# HTTP port for the management API + health check.
PORT=8090

# Shared bearer token the frontend Admin panel uses to call this service.
# Generate a long random string. Required in production.
OPENPROJECT_MCP_ADMIN_TOKEN=change-me

# Where the persisted config/cursor/review-log JSON lives.
# On Railway, point this at a mounted volume so it survives restarts.
OPENPROJECT_MCP_STATE_PATH=./data/state.json

# --- OpenProject read path (official, read-only MCP server) ---
# The OpenProject MCP endpoint (OpenProject 17.2+). Usually <your-openproject>/mcp
OPENPROJECT_MCP_URL=https://openproject.example.com/mcp
# Bearer token / API key used to authenticate to the MCP server.
OPENPROJECT_MCP_TOKEN=

# --- OpenProject write path (REST API v3) ---
# Base URL of the OpenProject instance (no trailing /api/v3).
OPENPROJECT_API_BASE_URL=https://openproject.example.com
# OpenProject API key used to POST review comments back to work packages.
OPENPROJECT_API_TOKEN=

# --- Claude review agent ---
ANTHROPIC_API_KEY=
# Model used to generate the insight/recommendation/methodology review.
OPENPROJECT_MCP_MODEL=claude-opus-4-8

# Default sync interval (seconds). Editable at runtime via the MCP config page.
OPENPROJECT_MCP_INTERVAL_SECONDS=3600
